{
  "name": "com.eyecatch.googlenest.starling",
  "version": "1.0.0",
  "main": ".homeybuild/app.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rm -rf .homeybuild",
    "prebuild": "npm run clean",
    "postbuild": "cp app.json .homeybuild/ && cp -r settings .homeybuild/ && cp -r assets .homeybuild/ 2>/dev/null || true && for d in drivers/*/; do cp -r \"$d\"*.json \"$d\"pair \"$d\"assets .homeybuild/$d 2>/dev/null || true; done && chmod -R a+r .homeybuild/",
    "lint": "eslint --ext .js,.ts src/",
    "lint:fix": "eslint --ext .js,.ts src/ --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepare": "npm run build",
    "preversion": "npm run lint && npm run typecheck && npm run test"
  },
  "devDependencies": {
    "@types/homey": "npm:homey-apps-sdk-v3-types@^0.3.12",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.3",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "eslint": "^8.57.1",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
